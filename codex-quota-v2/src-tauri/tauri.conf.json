{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex Quota Monitor",
  "version": "2.0.0",
  "identifier": "com.codexquotamonitor.v2",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run frontend:build",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "Codex 额度",
        "width": 210,
        "height": 30,
        "minWidth": 210,
        "minHeight": 30,
        "maxWidth": 380,
        "maxHeight": 200,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "visible": false,
        "shadow": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "displayLanguageSelector": false
      }
    }
  }
}
